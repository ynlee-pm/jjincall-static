{
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/manager/:path*",  "destination": "/index.html" },
    { "source": "/student/:path*",  "destination": "/index.html" },
    { "source": "/admin",           "destination": "/index.html" },
    { "source": "/admin/:path*",    "destination": "/index.html" }
  ]
}
